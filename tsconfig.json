{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "WebWorker"],
    "types": ["node", "@cloudflare/workers-types"],
    "skipLibCheck": true
  },
  "include": ["worker/src/**/*.ts", "worker/test/**/*.ts"]
}
